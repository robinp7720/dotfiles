;; State for the control center surface. Values are refreshed on demand by
;; scripts/control_center.sh so the daemon stays idle while the panel is closed.

(defvar cc_clock "Loading...")
(defvar cc_date "Loading...")
(defvar cc_next_event "Checking calendar...")
(defvar cc_media "Nothing playing")
(defvar cc_bluetooth "Checking...")
(defvar cc_headphones "Checking...")
(defvar cc_power_profile "Checking...")
(defvar cc_battery "Checking...")
(defvar cc_network "Checking...")
